PORT=10000
NODE_ENV=production
DATABASE_URL=replace-with-mongodb-atlas-uri
FRONTEND_URL=https://your-frontend-render-url.onrender.com
CORS_ORIGINS=https://your-frontend-render-url.onrender.com
JWT_SECRET=replace-with-strong-jwt-secret
JWT_EXPIRE=30d
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=models/gemini-2.5-flash
ALLOW_MOCK_QUESTIONS=false
ENABLE_PDF_OCR=true
OCR_LANGUAGE=eng
OCR_PAGE_LIMIT=20
PDF_OCR_MIN_TEXT_CHARS=30
